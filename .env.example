# Archivo de referencia. Con docker-compose.yml no necesitas este .env para correr el proyecto.
# Úsalo solo si quieres sobreescribir algún valor por defecto.

# PostgreSQL
POSTGRES_SUPERPASSWORD=postgres123
APP_DB_PASSWORD=app123
AIRFLOW_DB_PASSWORD=airflow123

# Airflow Fernet Key (generado con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# El valor en docker-compose.yml es válido pero inseguro — reemplázalo en producción
AIRFLOW_FERNET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# LocalStack Auth Token (requerido con las imágenes actuales)
LOCALSTACK_AUTH_TOKEN=your_localstack_token

# S3 buckets
S3_RAW_BUCKET=rappi-handoff-raw
S3_ARCHIVE_BUCKET=rappi-handoff-archive

# Agent LLM (via LiteLLM — see https://docs.litellm.ai/docs/providers)
AGENT_ROUTER_MODEL=openai/gpt-5.4-mini
AGENT_MODEL=openai/gpt-5.4-nano
AGENT_CHEAP_MODEL=openai/gpt-5.4-nano
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2048
OPENAI_API_KEY=your_openai_api_key

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-46103f52-db37-4b8e-b88a-0aac1809c229
LANGFUSE_SECRET_KEY=sk-lf-afbc4b53-5a02-4b7a-84fa-109b2446b2f4
LANGFUSE_HOST=https://cloud.langfuse.com

TTS_BACKEND=kokoro
EDGE_TTS_VOICE=es-CO-SalomeNeural
PIPER_VOICE_PATH=/models/es_MX-ald-medium.onnx
KOKORO_MODEL_PATH=/models/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=/models/voices-v1.0.bin
KOKORO_VOICE=ef_dora
KOKORO_LANG=es


# Recall.ai — Google Meet / Zoom bot integration
# Get your API key at https://app.recall.ai
RECALL_API_KEY=your_recall_ai_api_key
RECALL_API_BASE_URL=https://us-east-1.recall.ai
# Public URL of the agent server — required for Recall.ai to reach our WebSocket and output page
# For local dev use ngrok: ngrok http 8002  →  copy the https://... URL here
PUBLIC_BASE_URL=https://your-ngrok-or-public-url.ngrok.io
# URL to share as screenshare when the bot joins a meeting.
# PoC: https://www.google.com — later replace with your Portal Partners mockup URL.
# Leave empty to disable screenshare.
SCREENSHARE_DEFAULT_URL=https://www.google.com
